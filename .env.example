# ── HiSol AI Agent — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Most tools work WITHOUT any API key when used as an MCP server
# (the host platform such as Claude Code handles the AI connection).

# ── Optional: C-007 API Gateway (direct LLM calls from the server) ───────────
# Only needed if you want the server to call Claude directly (not via MCP host)
ANTHROPIC_API_KEY=

# ── Optional: Additional LLM providers for C-007 gateway ────────────────────
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ── Server Configuration ─────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Feature Flags (all enabled by default) ───────────────────────────────────
ENABLE_V4_PERSONAS=true
ENABLE_AUTO_TRIGGER=true
ENABLE_ORCHESTRATION=true

# ── HTTP Gateway (optional, only if running as standalone HTTP server) ────────
HTTP_PORT=8080
