{
  "name": "hisol-unified-mcp",
  "version": "3.1.0",
  "description": "ARHA runtime — 10-mode emotion matrix engine with persona registry",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "arha-runtime": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/server.ts",
    "dev:http": "tsx watch src/http-gateway.ts",
    "start": "node dist/server.js",
    "test": "tsx --test \"src/am/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"src/am/**/*.test.ts\"",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist"
  },
  "keywords": [
    "hisol",
    "arha",
    "am",
    "artificial-mind",
    "mcp",
    "emotion-intelligence",
    "ai-system",
    "two-mind-interference",
    "gamma-matrix"
  ],
  "author": "HiSol AI Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.64.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
